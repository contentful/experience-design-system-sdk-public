{
  "extends": "@tsconfig/node24",
  "compilerOptions": {
    "lib": ["ES2024"],
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],
    "sourceMap": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noEmitOnError": true,
    "noErrorTruncation": true,
    "pretty": true,
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true
  },
  "exclude": ["dist", "eslint.config.ts"]
}
