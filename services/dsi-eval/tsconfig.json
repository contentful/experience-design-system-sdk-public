{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@contentful/experience-design-system-cli/src/*": ["../../packages/experience-design-system-cli/src/*"],
      "@contentful/experience-design-system-types": ["../../packages/experience-design-system-types/src/index.ts"],
      "@contentful/experience-design-system-types/src/*": ["../../packages/experience-design-system-types/src/*"]
    }
  },
  "include": ["src/**/*"]
}
