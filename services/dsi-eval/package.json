{
  "name": "@contentful/dsi-eval",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "tsx src/index.ts",
    "start:save-baseline": "tsx src/index.ts --save-baseline",
    "pull-corpus": "git -C corpus pull 2>/dev/null || git clone \"${DSI_EVAL_CORPUS_REPO:?Set DSI_EVAL_CORPUS_REPO to your corpus repo SSH URL}\" corpus",
    "build-corpus": "tsx scripts/build-corpus.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.782.0",
    "@contentful/experience-design-system-cli": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
