  "expectedComponents": [
    {
      "name": "Accordion",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Declared prop is optional `align` with a default of `end`, plus child content.",
        "slotNotes": "Default slot for accordion item children."
      }
    },
    {
      "name": "AccordionHeader",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Declared props are `onClick`, `isExpanded`, `ariaId`, and optional `element`, plus children content.",
        "slotNotes": "Default slot for the header label content."
      }
    },
    {
      "name": "Avatar",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Declared props are `alt`, `isLoading`, `size`, `initials`, `src`, `tooltipProps`, `variant`, `colorVariant`, and `icon`, with defaults for `alt`, `isLoading`, `size`, `variant`, and `colorVariant`.",
        "slotNotes": "No slots."
      }
    },
    {
      "name": "Badge",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Local badge props are `variant`, required `children`, `size`, `startIcon`, `endIcon`, `textTransform`, and `as`, with additional inherited common and `div` HTML props.",
        "slotNotes": "Default slot for the badge label content."
      }
    },
    {
      "name": "CopyButton",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Local props are `onCopy`, `tooltipCopiedText`, `tooltipText`, `tooltipProps`, `label`, `isDisabled`, `size`, and required `value`, plus the inherited `ButtonProps` surface minus the omitted members.",
        "slotNotes": "Default slot for the button label."
      }
    },
    {
      "name": "IconBase",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The polymorphic icon base accepts `children`, `color`, `isActive`, `size`, and `viewBox`, plus inherited common, spacing, accessibility, and `as` props.",
        "slotNotes": "Default slot for SVG child content."
      }
    },
    {
      "name": "MenuList",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "No named local props beyond inherited common and `div` HTML wrapper props.",
        "slotNotes": "Default slot for menu content; `MenuListHeader` and `MenuListFooter` are composed from children rather than separate props."
      }
    },
    {
      "name": "Navbar",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Declared props are `logo`, `promotions`, `switcher`, `mainNavigation`, `secondaryNavigation`, `account`, `mobileNavigation`, `mobileNavigationProps`, `contentMaxWidth`, `variant`, and `aria`, plus optional `id`.",
        "slotNotes": "No slots; composition happens through ReactNode props."
      }
    },
    {
      "name": "Option",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Local prop is `isDisabled`, with additional inherited common and native `option` element props for value and label text handling.",
        "slotNotes": "Default slot for the option label text."
      }
    },
    {
      "name": "ScreenReaderOnly",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Declared props are optional `as`, `children`, and inherited common props, with `as` defaulting to `div`.",
        "slotNotes": "Default slot for screen-reader-only content."
      }
    },
    {
      "name": "Switch",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The component inherits the `BaseCheckboxProps` surface except for `type` and `isIndeterminate`, and forwards its label content as children.",
        "slotNotes": "Default slot for the switch label."
      }
    },
    {
      "name": "TooltipContent",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Declared props are the enhanced tooltip content fields from `WithEnhancedContent`, plus optional `id`, `as`, and inherited common wrapper props.",
        "slotNotes": "No slots."
      }
    }
