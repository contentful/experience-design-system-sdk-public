  "expectedComponents": [
    {
      "name": "CalendarHeader",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Public props come from `CalendarHeaderProps<DateType>`: optional `className`, `style`, and `validRange`, plus required `prefixCls`, `value`, `generateConfig`, `locale`, `mode`, `fullscreen`, `onChange`, and `onModeChange`.",
        "slotNotes": "No authored slots; the component renders internal year and month controls and mode switchers."
      }
    },
    {
      "name": "CascaderPanel",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The panel forwards a picked `CascaderProps` surface, including panel and root class controls, disabled state, icons, direction, not-found content, and the `multiple` toggle.",
        "slotNotes": "No authored slots; this is a wrapper around the rc-cascader panel."
      }
    },
    {
      "name": "DisabledContextProvider",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The provider exposes optional `disabled` plus `children` through `DisabledContextProps`.",
        "slotNotes": "Default slot for wrapped children."
      }
    },
    {
      "name": "EllipsisMeasure",
      "verdict": "partial",
      "expectedNotes": {
        "propNotes": "Authored props include `enableMeasure`, `text`, `width`, `rows`, required render-prop `children`, `onEllipsis`, `expanded`, and `miscDeps`.",
        "slotNotes": "Default slot-like child content is provided through the required render-prop `children` callback."
      }
    },
    {
      "name": "FormProvider",
      "verdict": "partial",
      "expectedNotes": {
        "propNotes": "The provider exposes optional `prefixCls` plus forwarded `RcFormProviderProps` and child content.",
        "slotNotes": "Default child content."
      }
    },
    {
      "name": "InternalBreadcrumbItem",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Breadcrumb item props include optional `prefixCls`, `href`, `menu`, `dropdownProps`, `dropdownIcon`, `onClick`, `className`, `style`, `separator`, and `children`.",
        "slotNotes": "Default child content."
      }
    },
    {
      "name": "ItemHolder",
