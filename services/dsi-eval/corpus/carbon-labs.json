  "expectedComponents": [
    {
      "name": "Accordion",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The wrapper explicitly declares optional `className` and also accepts the `MdxComponent` child content it forwards into Carbon's accordion.",
        "slotNotes": "Default slot for accordion item children."
      }
    },
    {
      "name": "AIPromptTile",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Declared props include required `variant` and `tileId`, optional navigation/copy props such as `href`, `title`, `disabledTaskLabel`, `productName`, `promptPlaceholder`, `primaryIcon`, `aiLabelVariant`, `aiLabelText`, `aiLabelTagType`, `onClick`, `ariaLabel`, `open`, `isLoading`, and `isDisabled`.",
        "slotNotes": "No authored slots; the prompt tile renders its own input and button structure."
      }
    },
    {
      "name": "AnchorLink",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The component exposes optional `to` and requires child text content that becomes the anchor label and slug source.",
        "slotNotes": "Default slot for the anchor text children."
      }
    },
    {
      "name": "AuthContext",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The public reactive API is the single `props` field of type `AuthContextProps`; the many `render*` methods are internal Lit helpers, not component props.",
        "slotNotes": "No authored slots."
      }
    },
    {
      "name": "Bubble",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Should expose required `align`, `target`, and `open`, optional `dropShadow` and `highContrast`, plus inherited div props from `Omit<HTMLProps<HTMLDivElement>, 'target'>`.",
        "slotNotes": "Default slot for the bubble content."
      }
    },
    {
      "name": "ClabsChatFormula",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The wrapper's public reactive API is the inherited `content` property from the base formula element.",
        "slotNotes": "No authored slots."
      }
    },
    {
      "name": "CLABSStylePickerIcon",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The wrapper class does not declare any authored public props beyond the base Lit element surface.",
        "slotNotes": "No authored slots."
      }
    },
    {
      "name": "H2",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Should expose optional `className`, `headingClassName`, and `noAnchor`, with heading content passed separately.",
        "slotNotes": "Default slot for the heading content."
      }
    },
    {
      "name": "InlineCode",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The authored contract is the required child code element that the wrapper passes into Carbon's inline `CodeSnippet`.",
        "slotNotes": "Default slot for the inline code content."
      }
    },
    {
      "name": "ProfileReadOnly",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Should expose optional `className` and `items` for the read-only profile rows.",
        "slotNotes": "No slots."
      }
    },
    {
      "name": "SplitPanel",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Should expose required `childrenBeforeSplit` and `childrenAfterSplit`, plus optional `className`, `defaultSplitValue`, `gap`, `onChange`, `orientation`, `splitMin`, `splitMax`, `splitKeyStepPixels`, and `splitShiftKeyStepPixels`.",
        "slotNotes": "No slots."
      }
    },
    {
      "name": "TrialPopover",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Should expose the reactive `open` and `trialConfig` properties declared on the Lit element.",
        "slotNotes": "Default slot for the popover trigger content."
      }
    }
