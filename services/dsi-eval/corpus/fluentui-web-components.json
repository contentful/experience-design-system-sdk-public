  "expectedComponents": [
    {
      "name": "Accordion",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The public prop surface is the `expandmode` attribute.",
        "slotNotes": "Default slot for accordion items."
      }
    },
    {
      "name": "AccordionItem",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Inherited public props include `headinglevel`, `expanded`, `disabled`, and `id`, and local props include `size`, `markerPosition`, and `block`.",
        "slotNotes": "Public slots are `start`, `heading`, default, `marker-expanded`, and `marker-collapsed`."
      }
    },
    {
      "name": "AnchorButton",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Inherited public anchor props include `download`, `href`, `hreflang`, `ping`, `referrerpolicy`, `rel`, `target`, and `type`, plus local `appearance`, `shape`, `size`, and `iconOnly`.",
        "slotNotes": "Public slots are `start`, default, and `end`."
      }
    },
    {
      "name": "Button",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Inherited public button props include `autofocus`, `disabled`, `disabledFocusable`, `formAction`, `formAttribute`, `formEnctype`, `formMethod`, `formNoValidate`, `formTarget`, `name`, `type`, `value`, and the public `defaultSlottedContent` reference, plus local `appearance`, `shape`, `size`, and `iconOnly`.",
        "slotNotes": "Public slots are `start`, default, and `end`."
      }
    },
    {
      "name": "DialogBody",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "No public props are declared on the class.",
        "slotNotes": "The template exposes `title`, `title-action`, `close`, default, and `action` slots."
      }
    },
    {
      "name": "Divider",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Local public props are `alignContent`, `appearance`, and `inset`, and inherited public props include `orientation` and `role`.",
        "slotNotes": "The template exposes a default slot for divider content."
      }
    },
    {
      "name": "Image",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Public props are `block`, `bordered`, `shadow`, `fit`, and `shape`.",
        "slotNotes": "The image template exposes a default slot."
      }
    },
    {
      "name": "MenuButton",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The component inherits the button surface, including `autofocus`, `disabled`, `disabledFocusable`, `formAction`, `formAttribute`, `formEnctype`, `formMethod`, `formNoValidate`, `formTarget`, `name`, `type`, `value`, `defaultSlottedContent`, `appearance`, `shape`, `size`, and `iconOnly`.",
        "slotNotes": "Public slots are `start`, default, and `end`."
      }
    },
    {
      "name": "ProgressBar",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Local public props are `thickness` and `shape`, and the inherited public prop is `validationState`.",
        "slotNotes": "No slots."
      }
    },
    {
      "name": "Spinner",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Public props are `size` and `appearance`.",
        "slotNotes": "No slots."
      }
    },
    {
      "name": "Tabs",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Inherited public props include `activeid`, `activetab`, and `orientation`, and local public props include `appearance`, `disabled`, and `size`.",
        "slotNotes": "The template exposes `start`, `tab`, `end`, and `tabpanel` slots."
      }
    },
    {
      "name": "Tooltip",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Public props are `id`, `delay`, `positioning`, and `anchor`; internal fields such as `elementInternals` and the anchor event handlers should not surface.",
        "slotNotes": "The tooltip template exposes a default slot for tooltip content."
      }
    }
