{
  "repo": "spectrum-web-components",
  "repoUrl": "https://github.com/adobe/spectrum-web-components",
  "rawComponents": [
    {
      "name": "Asset",
      "source": "1st-gen/packages/asset/src/Asset.ts",
      "framework": "web-component",
      "props": [],
      "slots": [
        {
          "name": "default",
          "isDefault": true,
          "description": "content to be displayed in the asset when an acceptable value for `file` is not present"
        }
      ]
    },
    {
      "name": "Badge",
      "source": "1st-gen/packages/badge/src/Badge.ts",
      "framework": "web-component",
      "props": [
        {
          "name": "variant",
          "type": "BadgeVariantS1",
          "required": false,
          "defaultValue": "informative"
        }
      ],
      "slots": [
        {
          "name": "default",
          "isDefault": true,
          "description": "Text label of the badge"
        },
        {
          "name": "icon",
          "isDefault": false,
          "description": "Optional icon that appears to the left of the label"
        }
      ]
    },
    {
      "name": "Divider",
      "source": "1st-gen/packages/divider/src/Divider.ts",
      "framework": "web-component",
      "props": [],
      "slots": []
    },
    {
      "name": "Icon",
      "source": "1st-gen/packages/icon/src/Icon.ts",
      "framework": "web-component",
      "props": [
        {
          "name": "label",
          "type": "any",
          "required": false,
          "defaultValue": ""
        },
        {
          "name": "name",
          "type": "string",
          "required": false
        },
        {
          "name": "size",
          "type": "'xxs' | 'xs' | 's' | 'm' | 'l' | 'xl' | 'xxl'",
          "required": false
        },
        {
          "name": "src",
          "type": "string",
          "required": false
        }
      ],
      "slots": []
    },
    {
      "name": "ProgressCircle",
      "source": "1st-gen/packages/progress-circle/src/ProgressCircle.ts",
      "framework": "web-component",
      "props": [
        {
          "name": "staticColor",
          "type": "ProgressCircleStaticColorS1",
          "required": false
        }
      ],
      "slots": [
        {
          "name": "default",
          "isDefault": true
        }
      ]
    },
    {
      "name": "StatusLight",
      "source": "1st-gen/packages/status-light/src/StatusLight.ts",
      "framework": "web-component",
      "props": [
        {
          "name": "disabled",
          "type": "any",
          "required": false,
          "defaultValue": "false"
        },
        {
          "name": "variant",
          "type": "StatusLightVariantS1",
          "required": false,
          "defaultValue": "info"
        }
      ],
      "slots": [
        {
          "name": "default",
          "isDefault": true,
          "description": "text label of the Status Light"
        }
      ]
    }
  ],
  "expectedComponents": [
    {
      "name": "Asset",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Inherited public props are `label` and `variant`.",
        "slotNotes": "Default slot for custom asset content when no `variant` is set."
      }
    },
    {
      "name": "Badge",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Local public props include `variant`, `subtle`, and `outline`, and the inherited public surface also includes `fixed` and `size`.",
        "slotNotes": "Default slot for the label plus a named `icon` slot."
      }
    },
    {
      "name": "Divider",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Inherited public props are `size`, `staticColor`, and `vertical`.",
        "slotNotes": "No slots."
      }
    },
    {
      "name": "Icon",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "Inherited public props are `label` and `size`.",
        "slotNotes": "Default slot for slotted SVG markup."
      }
    },
    {
      "name": "ProgressCircle",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The component overrides `staticColor` and inherits `progress`, `indeterminate`, `size`, and `label`.",
        "slotNotes": "Default slot for the accessible label content."
      }
    },
    {
      "name": "StatusLight",
      "verdict": "accurate",
      "expectedNotes": {
        "propNotes": "The component overrides `variant` and inherits the public `size` prop.",
        "slotNotes": "Default slot for the status label."
      }
    }
  ]
}
